{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "minLength": 10,
      "maxLength": 2000
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "techs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skill.skill",
      "inversedBy": "projects"
    },
    "screens": {
      "type": "component",
      "component": "project.project-screen",
      "repeatable": true,
      "min": 1,
      "max": 100
    },
    "demo_url": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255
    },
    "github_repo": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255
    }
  }
}
